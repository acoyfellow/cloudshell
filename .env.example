# CloudShell Environment Variables
# Copy this file to .env and fill in your values
# Then run: wrangler secret put <KEY> for each secret

# ===========================================
# REQUIRED SECRETS (set via wrangler secret put)
# ===========================================

# JWT secret for authentication tokens
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secure-random-string-here

# R2 API credentials for persistent storage
# Get from: https://dash.cloudflare.com/?to=/:account/r2/overview
# Create API token with Object Read & Write permissions
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key

# ===========================================
# REQUIRED VARIABLES (set in wrangler.jsonc)
# ===========================================

# Your Cloudflare Account ID
# Find at: https://dash.cloudflare.com/?to=/:account
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 bucket name for user data persistence
R2_BUCKET_NAME=cloudshell-user-data

# ===========================================
# OPTIONAL (for basic auth fallback)
# ===========================================

# Default admin credentials (optional)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=admin