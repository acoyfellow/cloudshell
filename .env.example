ALCHEMY_PASSWORD=change-me
BETTER_AUTH_SECRET=change-me

# App URL (auth callbacks, cookies). Port-forward URLs use *. + this hostname (wildcard DNS).
# BETTER_AUTH_URL=http://localhost:5173

# Optional comma-separated extra trusted origins.
# BETTER_AUTH_TRUSTED_ORIGINS=https://your-app.example.com

# Optional override for local terminal tickets.
# TERMINAL_TICKET_SECRET=change-me-too

# Optional R2-backed workstation sync.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# R2_ACCOUNT_ID=
# CLOUDFLARE_ACCOUNT_ID=

# Optional: deploy minimal Node `ws` parity container + guarded GET wss://<api>/terminal?secret=...
# TERMINAL_PARITY_SECRET=long-random-string

# Application-level signup allow-list (comma-separated emails).
# Empty/unset means all signups are denied; existing accounts still log in.
# Required in any deployed stage that should permit new signups.
# ALLOWED_EMAILS=jordan@example.com,other@example.com
