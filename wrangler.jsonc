{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudshell",
  // account_id: Set via CLOUDFLARE_ACCOUNT_ID env var or remove to use default
  "main": "src/index.ts",
  "compatibility_date": "2025-10-13",
  "compatibility_flags": ["nodejs_compat"],
  "containers": [
    {
      "max_instances": 5,
      "class_name": "CloudShellTerminal",
      "image": "./Dockerfile",
      "volumes": [
        {
          "name": "shell-data",
          "mount_path": "/home/user",
        },
      ],
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "Sandbox",
        "class_name": "CloudShellTerminal",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v6",
      "new_sqlite_classes": ["CloudShellTerminal"],
    },
  ],
  "observability": {
    "enabled": true,
  },
}
