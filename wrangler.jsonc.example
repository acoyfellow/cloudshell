{
  "name": "cloudshell",
  "account_id": "YOUR_CLOUDFLARE_ACCOUNT_ID",
  "main": "src/index.ts",
  "compatibility_date": "2025-10-13",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "containers": [
    {
      "max_instances": 5,
      "class_name": "CloudShellTerminal",
      "image": "./Dockerfile"
    }
  ],
  "r2_buckets": [
    {
      "binding": "USER_DATA",
      "bucket_name": "cloudshell-user-data"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "USERS_KV",
      "id": "YOUR_KV_NAMESPACE_ID"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "Sandbox",
        "class_name": "CloudShellTerminal"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CloudShellTerminal"]
    }
  ],
  "vars": {
    "R2_BUCKET_NAME": "cloudshell-user-data",
    "R2_ACCOUNT_ID": "YOUR_CLOUDFLARE_ACCOUNT_ID"
  },
  "observability": {
    "enabled": true
  }
}