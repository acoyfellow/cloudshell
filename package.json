{
  "name": "cloudshell",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "dev": "alchemy dev",
    "deploy": "alchemy deploy --stage runner",
    "destroy": "alchemy destroy --stage runner",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "bun run check",
    "db:better-auth": "bunx @better-auth/cli generate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:local": "wrangler d1 migrations apply cloudshell-db --local",
    "db:remote": "wrangler d1 migrations apply cloudshell-db --remote",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.14.7",
    "@cloudflare/workers-types": "4.20260418.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.1",
    "@sveltejs/adapter-cloudflare": "7.2.8",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "25.6.0",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "drizzle-kit": "0.31.10",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "svelte": "5.55.4",
    "svelte-check": "^4.4.6",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "wrangler": "4.83.0"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.2",
    "@lucide/svelte": "^1.8.0",
    "cloudterm": "github:acoyfellow/cloudterm#v0.0.7",
    "agents": "^0.11.4",
    "alchemy": "^0.91.2",
    "better-auth": "1.6.5",
    "drizzle-orm": "0.45.2",
    "effect": "3.21.1",
    "hono": "4.12.14",
    "zod": "^4.3.6"
  },
  "type": "module",
  "patchedDependencies": {
    "alchemy@0.77.5": "patches/alchemy@0.77.5.patch"
  }
}
